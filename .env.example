# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:55432/lazarus_db

# Neo4j Aura (or local Docker)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=
AURA_INSTANCENAME=

# Redis
REDIS_URL=redis://redis:6379

# Reasoning Models
DEDALUS_API_KEY=
DEDALUS_ORG_ID=
DEDALUS_BASE_URL=https://api.dedaluslabs.ai
DEDALUS_ADVOCATE_MODEL=google/gemini-2.5-flash
DEDALUS_SKEPTIC_MODEL=k2-think-v2
DEDALUS_JUDGE_MODEL=openai/gpt-5-mini
DEDALUS_GEMINI_PROVIDER=google

# LLM Keys
GEMINI_API_KEY=
K2_API_KEY=
K2_API_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2

# Spectrum / local iMessage bridge
SPECTRUM_PROJECT_ID=
SPECTRUM_SECRET_KEY=
IMESSAGE_LOCAL=true
SPECTRUM_BASE_URL=http://127.0.0.1:8765
SPECTRUM_SEND_PATH=/messages
SPECTRUM_REPLY_PATH=/messages
SPECTRUM_RECIPIENT=

# Optional model keys for external runtimes
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_SKEPTIC_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# OpenClaw bridge
OPENCLAW_HOME=./openclaw
OPENCLAW_SHARED_TOKEN=

# Optional local service hooks
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=

# Optional iMessage fallback
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_CHAT_GUID=
BLUEBUBBLES_API_PATH=/api/v1

# Deployment
DEPLOY_TARGET=local
