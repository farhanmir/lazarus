# Leave unset for local dev: Vite proxies /api, /assets, /runs, … → http://127.0.0.1:8000 (see vite.config.js).
# Set only when the UI is hosted on a different origin than the API (e.g. deployed frontend).
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: if FastAPI is not on localhost:8000
# VITE_PROXY_TARGET=http://127.0.0.1:8000
